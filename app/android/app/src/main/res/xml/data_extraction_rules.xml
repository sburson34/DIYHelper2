<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data extraction rules. We disable both cloud backup and
  device-to-device transfer for privacy-sensitive content (photos, analyses).
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="root" path="." />
  </cloud-backup>
  <device-transfer>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="root" path="." />
  </device-transfer>
</data-extraction-rules>
