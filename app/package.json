{
  "name": "DIYHelper2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "kill-metro": "npx kill-port 8081 2>/dev/null; echo 'Port 8081 cleared'",
    "env": "bash scripts/load-env.sh",
    "android": "npm run kill-metro && bash scripts/load-env.sh react-native run-android",
    "ios": "npm run kill-metro && bash scripts/load-env.sh react-native run-ios",
    "start": "npm run kill-metro && bash scripts/load-env.sh react-native start",
    "build:beta": "bash scripts/load-env.sh bash android/gradlew -p android assembleRelease",
    "build:beta:bundle": "bash scripts/load-env.sh bash android/gradlew -p android bundleRelease",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@sentry/react-native": "^6.22.0",
    "expo": "~55.0.9",
    "expo-audio": "~55.0.9",
    "expo-camera": "~55.0.13",
    "expo-constants": "~55.0.9",
    "expo-image-picker": "~55.0.16",
    "expo-notifications": "~55.0.17",
    "expo-print": "~55.0.12",
    "expo-sharing": "~55.0.17",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~55.0.17",
    "react": "19.2.4",
    "react-native": "0.83.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-tts": "^4.1.1",
    "react-native-vision-camera": "^4.6.0",
    "react-native-worklets": "0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/cli-server-api": "^20.1.3",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@react-native/metro-config": "0.83.0",
    "@react-native/typescript-config": "0.83.0",
    "babel-jest": "^29.6.3",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "typescript": "5.0.4"
  },
  "overrides": {
    "eslint-plugin-jest": "27.9.0"
  }
}
